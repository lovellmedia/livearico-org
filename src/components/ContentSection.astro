---
export interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<div class="content-section">
  {title && <h2>{title}</h2>}
  <slot />
</div>

<style>
  .content-section {
    margin-bottom: 2.5rem;
  }
  .content-section h2 {
    color: #2d3748;
    font-size: 1.75rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #e2e8f0;
  }
  .content-section :global(h3) {
    color: #4a5568;
    font-size: 1.35rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .content-section :global(p) {
    line-height: 1.8;
    margin-bottom: 1rem;
    color: #333;
  }
  .content-section :global(ul), .content-section :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .content-section :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .content-section :global(a) {
    color: #2c5282;
    text-decoration: underline;
  }
  .content-section :global(a:hover) {
    color: #1a365d;
  }
  .content-section :global(blockquote) {
    border-left: 4px solid #2c5282;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #555;
    font-style: italic;
  }
</style>
